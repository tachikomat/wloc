#!name=WLOC Personal
#!desc=Patch Apple WLOC network location response for Shadowrocket. Edit arguments to use your own fixed point or random range.
#!author=local
#!category=Tools

[Script]
Apple WLOC Personal = type=http-response,pattern=^https?:\/\/gs-loc(-cn)?\.apple\.com\/clls\/wloc,requires-body=1,binary-body-mode=1,max-size=0,timeout=30,script-path=https://raw.githubusercontent.com/YOUR_NAME/wloc/main/dist/response-shadowrocket.js,argument=mode=random&centerLatitude=30.30329&centerLongitude=120.10133&radius=5&accuracy=25&altitude=8

[MITM]
hostname = %APPEND% gs-loc.apple.com, gs-loc-cn.apple.com
